frontend/.yarn/install-state.gz

# Nuxt
frontend/.nuxt/
frontend/.output/

# Build output
dist/
frontend/dist/

# Cache
frontend/.eslintcache
frontend/.stylelintcache
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ========================
# Terraform
# ========================
infrastructure/**/.terraform/
infrastructure/**/.terraform.lock.hcl
